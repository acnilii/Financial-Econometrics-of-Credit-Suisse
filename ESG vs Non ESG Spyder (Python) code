OUT_DIR = os.path.join(os.path.dirname(DATA_DIR), "outputs")
os.makedirs(OUT_DIR, exist_ok=True)

cross_section.to_csv(os.path.join(OUT_DIR, "cross_section_data.csv"), index=False)
stationarity.to_csv(os.path.join(OUT_DIR, "stationarity_tests.csv"), index=False)

with open(os.path.join(OUT_DIR, "regression_results.txt"), "w") as f:
    f.write(model.summary().as_text())

print(f"\nAll outputs saved to: {OUT_DIR}")
