# ---- 1. Install and load packages ----
# Run install.packages(...) ONLY the first time. After that, comment them out.
install.packages(c("readxl", "dplyr", "tidyr", "ggplot2", "tseries", "lmtest", "sandwich", "stringr"))

library(readxl)    # read Excel files
library(dplyr)     # data manipulation
library(tidyr)     # reshape data
library(ggplot2)   # plots
library(tseries)   # ADF and KPSS unit root tests
library(lmtest)    # robust regression diagnostics
library(sandwich)  # robust standard errors
library(stringr)   # string handling

# ---- 2. Define index metadata ----
# ESG dummy = 1 if file name starts with "ESG" or contains an ESG label
# (FTSE4Good and MSCI KLD are also ESG-labelled products even without "ESG" in the name)
indices <- tibble::tribble(
  ~file,                          ~index_name,             ~esg_dummy, ~esg_score,
  "FTSE All World.xlsx",          "FTSE All World",        0,          0,
  "FTSE4Good All World.xlsx",     "FTSE4Good All World",   1,          1,
  "MSCI KLD Good.xlsx",           "MSCI KLD 400 Social",   1,          1,
  "MSCI US.xlsx",                 "MSCI US",               0,          0,
  "MSCI World ESG.xlsx",          "MSCI World ESG",        1,          1,
  "MSCI World.xlsx",              "MSCI World",            0,          0,
  "Stoxx ESG.xlsx",               "STOXX Global ESG",      1,          1,
  "Stoxx Global.xlsx",            "STOXX Global 1800",     0,          0
)

# >>> ACTION REQUIRED: Fill in esg_score values for ESG-labelled indices <
# Example: indices$esg_score[indices$index_name == "MSCI World ESG"] <- 7.8
# Get scores from MSCI/FTSE/STOXX factsheets. For non-ESG indices, you can
# either leave NA (they will be excluded from the score regression) OR
# fill in the underlying parent index ESG score if available.

# ---- 3. Function to read one index file ----
# Your screenshot shows the price history starts at row 19 (headers) / row 20 (data).
# Columns: Exchange Date | Close | Net | %Chg | Open | Low | High
read_index <- function(filepath) {
  raw <- read_excel(
    filepath,
    sheet     = 1,
    skip      = 18,
    col_names = TRUE
  )
  
  # Print names so we can verify (remove this line later)
  message("Columns found: ", paste(names(raw), collapse = ", "))
  
  df <- raw %>%
    select(date = 1, close = 2) %>%    # ← select by position, not name
    filter(!is.na(date), !is.na(close)) %>%
    mutate(
      date  = as.Date(as.numeric(date), origin = "1899-12-30"),  # ← Excel serial date fix
      close = as.numeric(close)
    ) %>%
    arrange(date)
  
  return(df)
}

# ---- 4. Read all files and build the panel of returns ----
data_folder <- "data"   # relative to your RStudio project folder

all_returns <- list()

for (i in seq_len(nrow(indices))) {
  fp <- file.path(data_folder, indices$file[i])
  message("Reading: ", fp)

  df <- read_index(fp)

  # Compute monthly log returns: ln(P_t / P_{t-1})
  df <- df %>%
    mutate(
      log_return = log(close / lag(close)),
      index_name = indices$index_name[i],
      esg_dummy  = indices$esg_dummy[i],
      esg_score  = indices$esg_score[i]
    ) %>%
    filter(!is.na(log_return))

  all_returns[[i]] <- df
}

panel <- bind_rows(all_returns)

# Quick check
cat("\n--- Panel summary ---\n")
print(panel %>% group_by(index_name) %>%
        summarise(n_obs = n(), start = min(date), end = max(date)))

# ---- 5. Risk-free rate (1-month US T-Bill) ----
# OPTION A (manual): download from FRED series "TB4WK" or "DGS1MO", save as data/risk_free.xlsx
#                    with columns: date, rf_annual_pct
# OPTION B (quick start): use a constant approximation just to test the pipeline.
#
# The code below uses OPTION B as a placeholder. REPLACE with OPTION A for your
# final thesis - using a constant rf will bias your excess returns.

# --- OPTION B placeholder (REPLACE with real data before final analysis) ---
panel <- panel %>%
  mutate(
    rf_monthly    = 0.02 / 12,                 # 2% annual / 12, placeholder only
    excess_return = log_return - rf_monthly
  )

