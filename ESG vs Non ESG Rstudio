# ---- 6. Stationarity tests on log returns (per index) ----
# ADF: H0 = non-stationary (we want to REJECT, p < 0.05)
# KPSS: H0 = stationary  (we do NOT want to reject, p > 0.05)
cat("\n--- Stationarity tests (per index) ---\n")
stationarity_results <- panel %>%
  group_by(index_name) %>%
  summarise(
    adf_pvalue  = suppressWarnings(adf.test(log_return)$p.value),
    kpss_pvalue = suppressWarnings(kpss.test(log_return)$p.value)
  )
print(stationarity_results)

# ---- 7. Build cross-sectional dataset for the static regression ----
# The model is cross-sectional: ONE observation per index, summarising performance
# over the chosen period. Here we use mean monthly excess return as Perf_i.
# (You can later split into "normal" vs "stress" subsamples.)

cross_section <- panel %>%
  group_by(index_name, esg_dummy, esg_score) %>%
  summarise(
    perf_mean   = mean(excess_return, na.rm = TRUE),
    perf_sd     = sd(excess_return,   na.rm = TRUE),
    sharpe_like = perf_mean / perf_sd,        # rough Sharpe ratio (monthly)
    n_obs       = n(),
    .groups = "drop"
  )

cat("\n--- Cross-sectional dataset ---\n")
print(cross_section)

# ---- 8. The static linear model ----
# Perf_i = alpha + beta1 * ESG_dummy_i + beta2 * ESG_score_i + epsilon_i

# Model 1: ESG dummy only (works with all 8 indices)
model_1 <- lm(perf_mean ~ esg_dummy, data = cross_section)
cat("\n=== Model 1: Perf ~ ESG dummy ===\n")
print(summary(model_1))

# Model 2: ESG dummy + ESG score (only runs once you fill in esg_score values)
if (sum(!is.na(cross_section$esg_score)) >= 4) {
  model_2 <- lm(perf_mean ~ esg_dummy + esg_score, data = cross_section)
  cat("\n=== Model 2: Perf ~ ESG dummy + ESG score ===\n")
  print(summary(model_2))

  # Robust (heteroskedasticity-consistent) standard errors
  cat("\n=== Model 2 with HC robust standard errors ===\n")
  print(coeftest(model_2, vcov = vcovHC(model_2, type = "HC3")))
} else {
  message("\nModel 2 skipped: fill in esg_score values in the 'indices' table first.")
}

# ---- 9. Visualisation ----
ggplot(cross_section, aes(x = factor(esg_dummy), y = perf_mean, label = index_name)) +
  geom_boxplot(alpha = 0.3) +
  geom_point(size = 3, colour = "steelblue") +
  geom_text(vjust = -1, size = 3) +
  scale_x_discrete(labels = c("0" = "Traditional", "1" = "ESG")) +
  labs(
    title = "Mean monthly excess return: ESG vs Traditional indices",
    x = NULL,
    y = "Mean monthly excess return"
  ) +
  theme_minimal()

# ---- 10. Save outputs ----
write.csv(cross_section,         "cross_section_results.csv", row.names = FALSE)
write.csv(stationarity_results,  "stationarity_results.csv",  row.names = FALSE)
saveRDS(panel, "panel_returns.rds")

